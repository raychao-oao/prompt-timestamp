{
  "description": "Prepend a timestamp to every user prompt so Claude knows the current time",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "date '+[%Y-%m-%d %H:%M %z | elapsed since previous stamp]'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
